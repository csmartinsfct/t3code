{
  "name": "electron-chrome-extensions",
  "version": "4.9.0",
  "description": "Chrome extension support for Electron",
  "keywords": [
    "chrome",
    "electron",
    "extensions"
  ],
  "license": "SEE LICENSE IN LICENSE.md",
  "author": "Samuel Maddock <sam@samuelmaddock.com>",
  "repository": "https://github.com/samuelmaddock/electron-browser-shell",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js"
    },
    "./browser-action": {
      "types": "./dist/types/browser-action.d.ts",
      "import": "./dist/esm/browser-action.mjs",
      "require": "./dist/cjs/browser-action.js"
    },
    "./dist/browser-action": {
      "types": "./dist/types/browser-action.d.ts",
      "import": "./dist/esm/browser-action.mjs",
      "require": "./dist/cjs/browser-action.js"
    },
    "./preload": "./dist/chrome-extension-api.preload.js"
  },
  "scripts": {
    "build": "bun run clean && node esbuild.config.js && tsc --project tsconfig.json --noCheck",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "echo 'skip'",
    "fmt": "echo 'skip'"
  },
  "dependencies": {
    "debug": "^4.3.1"
  },
  "devDependencies": {
    "@types/chai": "^4.2.14",
    "@types/chai-as-promised": "^7.1.3",
    "@types/chrome": "^0.0.300",
    "@types/mocha": "^8.0.4",
    "chai": "^4.2.0",
    "chai-as-promised": "^7.1.1",
    "colors": "^1.4.0",
    "electron": "^37.1.0",
    "esbuild": "^0.24.2",
    "minimist": "^1.2.7",
    "mocha": "^8.2.1",
    "ts-node": "^10.9.1",
    "typescript": "catalog:",
    "walkdir": "^0.4.1"
  },
  "peerDependencies": {}
}
