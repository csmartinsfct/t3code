{
  "name": "@t3tools/desktop",
  "version": "0.0.15",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "cd ../../packages/electron-chrome-extensions && bun run build && cd ../../apps/desktop && bun run --parallel dev:bundle dev:electron",
    "dev:bundle": "tsdown --watch",
    "dev:electron": "bun run scripts/dev-electron.mjs",
    "build": "cd ../../packages/electron-chrome-extensions && bun run build && cd ../../apps/desktop && tsdown",
    "start": "bun run scripts/start-electron.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "smoke-test": "node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "effect": "catalog:",
    "electron": "40.6.0",
    "electron-chrome-extensions": "workspace:*",
    "electron-chrome-web-store": "^0.13.0",
    "electron-updater": "^6.6.2",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@t3tools/contracts": "workspace:*",
    "@t3tools/shared": "workspace:*",
    "@types/chrome": "^0.0.300",
    "@types/node": "catalog:",
    "node-gyp": "^10",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "productName": "T3 Code (Alpha)"
}
